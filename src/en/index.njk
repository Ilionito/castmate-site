<style data-castmate-faq>
.castmate-faq { display: flex; flex-direction: column; gap: 12px; box-sizing: border-box; padding: 0; flex: 1 1 0; min-width: 0; max-width: 720px; }
.castmate-faq__item { background: rgb(255, 255, 255); border: 1px solid rgb(240, 240, 240); border-radius: 24px; overflow: hidden; transition: border-color 0.2s ease, box-shadow 0.2s ease; }
.castmate-faq__item[open] { border-color: rgb(220, 220, 220); }
.castmate-faq__summary { list-style: none; cursor: pointer; padding: 20px 24px; display: flex; justify-content: space-between; align-items: center; gap: 16px; font-family: 'Archivo', system-ui, sans-serif; font-weight: 500; font-size: clamp(14px, 1.6vw, 18px); color: rgb(80, 18, 2); }
.castmate-faq__summary::-webkit-details-marker { display: none; }
.castmate-faq__summary::marker { content: ''; }
.castmate-faq__question { flex: 1; line-height: 1.4; }
.castmate-faq__icon { flex-shrink: 0; width: 44px; height: 44px; border-radius: 50%; border: 1px solid rgb(240, 240, 240); background-color: rgb(255, 255, 255); position: relative; transition: background-color 0.18s ease, border-color 0.18s ease; }
.castmate-faq__icon::before, .castmate-faq__icon::after { content: ''; position: absolute; top: 50%; left: 50%; width: 14px; height: 1.5px; background-color: rgb(80, 18, 2); transform: translate(-50%, -50%); transition: background-color 0.18s ease, opacity 0.18s ease; }
.castmate-faq__icon::after { transform: translate(-50%, -50%) rotate(90deg); }
.castmate-faq__item[open] .castmate-faq__icon { background-color: rgb(80, 18, 2); border-color: rgb(80, 18, 2); }
.castmate-faq__item[open] .castmate-faq__icon::before, .castmate-faq__item[open] .castmate-faq__icon::after { background-color: rgb(255, 255, 255); }
.castmate-faq__item[open] .castmate-faq__icon::after { opacity: 0; }
.castmate-faq__answer { padding: 0 24px 24px; font-family: 'Archivo', system-ui, sans-serif; font-weight: 400; font-size: 16px; line-height: 1.55; color: rgb(155, 123, 110); animation: castmate-faq-fade 0.18s ease; }
@keyframes castmate-faq-fade { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: translateY(0); } }
/* Mobile/tablet: parent Container is column → take full available width */
@media (max-width: 1199.98px) { .castmate-faq { max-width: 100%; } }





/* --- CTA hover swap (label scale/blur) without Framer runtime --- */
a:hover .framer-1r36vle, [data-highlight="true"]:hover .framer-1r36vle {
  opacity: 0; transform: scale(0.8); filter: blur(5px); -webkit-filter: blur(5px);
  transition: opacity 0.22s ease, transform 0.22s ease, filter 0.22s ease;
}
a:hover .framer-1y6kmu5, [data-highlight="true"]:hover .framer-1y6kmu5 {
  opacity: 1; transform: none; filter: none; -webkit-filter: none;
  transition: opacity 0.22s ease, transform 0.22s ease, filter 0.22s ease;
}
.framer-1r36vle, .framer-1y6kmu5 { transition: opacity 0.22s ease, transform 0.22s ease, filter 0.22s ease; }
/* Hero pills (Candidatures centralisées / Organisation simplifiée / Entretiens
   fluidifiés / Prise de décisions accélérée) : forcer une item par ligne — la
   règle Framer d'origine met flex-wrap:wrap, ce qui pose items 2 et 3 côte à
   côte sur les viewports moyens. */
.framer-1i9jmh4 { flex-direction: column !important; flex-wrap: nowrap !important; align-items: flex-start !important; }
/* Hero dashboard mockup (.framer-8ekuwz "Dashboard") : force object-fit:cover
   sur tous les variants. La variante mobile Framer met object-fit:contain par
   défaut, ce qui laisse l'image en boîte aux lettres dans le cadre. */
.framer-8ekuwz img { object-fit: cover !important; width: 100% !important; height: 100% !important; }
/* Mobile : pousser le titre hero sous le header fixed 96 px. */
@media (max-width: 860px) {
  section.framer-1pwad70 h1 { margin-top: 25px !important; }
}
