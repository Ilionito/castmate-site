<style>
.faq{background:#f5f5f7;padding:50px 60px}
.faq__box{position:relative;max-width:1320px;margin:0 auto;display:flex;gap:64px;border:4px solid #fff;padding:40px}
.faq__left{flex:0 0 600px;position:sticky;top:116px;align-self:flex-start}
.faq__eyebrow{display:inline-flex;align-items:center;gap:8px;font-family:Inter,system-ui,sans-serif;font-size:14px;color:#081131}
.faq__eyebrow i{width:16px;height:16px;background:#d1e2ff;display:block}
.faq__left h2{font-size:60px;line-height:72px;letter-spacing:-1.5px;color:#081131;margin:24px 0 0;font-weight:700;font-family:Archivo,Inter,system-ui,sans-serif}
.faq__sub{font-size:18px;line-height:30.6px;color:#000;margin:16px 0 24px;font-family:Inter,system-ui,sans-serif}
.faq__list{flex:1;min-width:0}
.faq__item{border-top:.8px solid rgba(0,0,0,.06)}
.faq__item:first-child{border-top:none}
.faq__item summary{list-style:none;cursor:pointer;display:flex;align-items:center;justify-content:space-between;gap:24px;padding:24px}
.faq__item summary::-webkit-details-marker{display:none}
.faq__item summary::marker{content:''}
.faq__q{font-family:Archivo,Inter,system-ui,sans-serif;font-weight:500;font-size:20px;line-height:34px;color:#081131}
.faq__toggle{flex:none;width:42px;height:42px;border-radius:50%;background:#fff;border:1px solid #f0f0f0;position:relative;transition:background-color .18s ease,border-color .18s ease}
.faq__toggle::before,.faq__toggle::after{content:"";position:absolute;left:11px;right:11px;top:50%;height:2px;background:#081131;transform:translateY(-50%);transition:background-color .18s ease}
.faq__toggle::after{transform:translateY(-50%) rotate(90deg)}
.faq__item[open] .faq__toggle{background:#081131;border-color:#081131}
.faq__item[open] .faq__toggle::before{background:#fff}
.faq__item[open] .faq__toggle::after{display:none}
.faq__a{padding:0 24px 24px;font-family:Inter,system-ui,sans-serif;font-size:16px;line-height:27.2px;color:#000;max-width:475px}
@media(max-width:900px){.faq{padding:32px 20px}.faq__box{flex-direction:column;gap:24px;padding:24px}.faq__left{flex:auto;position:static}.faq__left h2{font-size:40px;line-height:48px}}
</style>

<section class="faq">
  <div class="faq__box">
    <div class="faq__left">
      <span class="faq__eyebrow"><i></i>{{ faq.eyebrow }}</span>
      <h2>{{ faq.title }}</h2>
      <p class="faq__sub">{{ faq.subtitle }}</p>
      <a class="framer-BcHjm framer-vKPZc framer-y6rgl framer-v-y6rgl framer-ptabo1" data-border="true" data-framer-name="Black Button" href="{{ faq.ctaUrl }}" style="--24qzme:16px;--border-bottom-width:1px;--border-color:rgba(255, 255, 255, 0.18);--border-left-width:1px;--border-right-width:1px;--border-style:solid;--border-top-width:1px;background-color:var(--token-e87a9e53-9616-4ac1-a333-52b3ec0bae9e, rgb(80, 18, 2));border-bottom-left-radius:12px;border-bottom-right-radius:12px;border-top-left-radius:12px;border-top-right-radius:12px;box-shadow:inset 0px 0.5px 0px 0px var(--token-4edd532c-629d-46fd-b18b-ec00004834dd, rgb(135, 135, 135)), inset 0px 2px 5.85px 0px rgba(255, 255, 255, 0.2)"><div class="framer-1e1dp4m" data-framer-name="Title"><div class="framer-1r36vle" data-framer-name="Holder" data-highlight="true" data-framer-component-type="RichTextContainer" tabindex="0" style="--extracted-r6o4lv:var(--token-a5026c65-8ddb-4a17-a393-1692158bf079, rgb(255, 255, 255));--framer-link-text-color:rgb(0, 153, 255);--framer-link-text-decoration:underline;filter:blur(0px);-webkit-filter:blur(0px);opacity:1;transform:none"><p class="framer-text framer-styles-preset-1uq2p9u" data-styles-preset="wZyDG7x5K" style="--framer-text-alignment:center;--framer-text-color:var(--extracted-r6o4lv, var(--token-a5026c65-8ddb-4a17-a393-1692158bf079, rgb(255, 255, 255)))">{{ faq.ctaLabel }}</p></div><div class="framer-1y6kmu5" data-framer-component-type="RichTextContainer" style="--extracted-r6o4lv:var(--token-a5026c65-8ddb-4a17-a393-1692158bf079, rgb(255, 255, 255));--framer-link-text-color:rgb(0, 153, 255);--framer-link-text-decoration:underline;filter:blur(5px);-webkit-filter:blur(5px);opacity:0;transform:scale(0.8)"><p class="framer-text framer-styles-preset-1uq2p9u" data-styles-preset="wZyDG7x5K" style="--framer-text-alignment:center;--framer-text-color:var(--extracted-r6o4lv, var(--token-a5026c65-8ddb-4a17-a393-1692158bf079, rgb(255, 255, 255)))">{{ faq.ctaLabel }}</p></div></div><div class="framer-ydgjmi" data-framer-name="Icon Wrap" style="background-color:var(--token-e87a9e53-9616-4ac1-a333-52b3ec0bae9e, rgb(80, 18, 2));border-bottom-left-radius:8px;border-bottom-right-radius:8px;border-top-left-radius:8px;border-top-right-radius:8px;box-shadow:inset 0px -0.8px 0.8px 0px rgba(255, 255, 255, 0.14), inset 0px 1px 0.8px 0px rgba(255, 255, 255, 0.29)"><svg class="framer-eivmu framer-17o9gnp" role="presentation" viewBox="0 0 24 24" style="--1m6trwb:0;--21h8s6:rgb(255, 255, 255);--pgex8v:1.5"><use href="#3166100823"/></svg></div></a>
    </div>
    <div class="faq__list">
      {% for item in faq.items %}
      <details class="faq__item"{% if loop.first %} open{% endif %}>
        <summary><span class="faq__q">{{ item.question }}</span><span class="faq__toggle" aria-hidden="true"></span></summary>
        {% if item.answer %}<div class="faq__a">{{ item.answer }}</div>{% endif %}
      </details>
      {% endfor %}
    </div>
  </div>
</section>
