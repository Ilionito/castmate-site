{# Vanilla site header — lit nav.json (logo, logoAlt, links, ctaLabel, ctaUrl).
   Variable optionnelle : `forceSolid = true` avant l'include pour rendre
   le header navy opaque par défaut (pages avec haut clair). #}
{% set _forceSolid = forceSolid | default(false) %}
<style data-site-header>
.site-header { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: transparent; transition: background-color .25s ease, box-shadow .25s ease; }
.site-header__inner { max-width: 1200px; margin: 0 auto; height: 70px; padding: 0 30px; display: flex; align-items: center; gap: 32px; }
.site-header__logo { display: inline-flex; align-items: center; flex: none; }
.site-header__logo img { height: 26px; width: auto; display: block; filter: brightness(0) invert(1); }
.site-header__nav { display: flex; gap: 24px; margin-left: auto; }
.site-header__nav a { color: #fff; text-decoration: none; font-family: 'Archivo', system-ui, sans-serif; font-size: 15px; font-weight: 500; }
.site-header__nav a:hover { opacity: .8; }
.site-header__cta { display: inline-flex; align-items: center; gap: 8px; background: #081131; color: #fff; border: 1px solid rgba(255, 255, 255, .45); border-radius: 12px; padding: 10px 16px; text-decoration: none; font-family: 'Archivo', system-ui, sans-serif; font-size: 15px; font-weight: 500; transition: border-color .2s ease, transform .2s ease; }
.site-header__cta:hover { border-color: rgba(255, 255, 255, .8); transform: translateY(-1px); }
.site-header__cta svg { display: block; }
.site-header__burger { display: none; flex-direction: column; gap: 5px; background: none; border: 0; padding: 8px; cursor: pointer; margin-left: auto; }
.site-header__burger span { width: 24px; height: 2px; background: #fff; border-radius: 2px; display: block; transition: transform .2s ease, opacity .2s ease; }
.site-header.is-solid { background: #081131; box-shadow: 0 1px 0 rgba(255, 255, 255, .08), 0 6px 20px rgba(0, 0, 0, .25); }
.site-drawer { position: fixed; top: 70px; left: 0; right: 0; background: #0d1231; display: flex; flex-direction: column; gap: 8px; padding: 24px 30px 32px; transform: translateY(-110%); transition: transform .28s cubic-bezier(.4, 0, .2, 1); pointer-events: none; z-index: 99; }
.site-drawer a { color: #fff; text-decoration: none; font-family: 'Archivo', system-ui, sans-serif; font-size: 22px; font-weight: 500; padding: 12px 0; }
.site-drawer a:last-child { margin-top: 8px; background: #081131; color: #fff; border: 1px solid rgba(255, 255, 255, .45); border-radius: 12px; padding: 14px 20px; text-align: center; font-size: 18px; }
.site-header.is-open .site-drawer { transform: translateY(0); pointer-events: auto; }
@media (max-width: 860px) {
  .site-header__nav, .site-header__cta { display: none; }
  .site-header__burger { display: flex; }
}
</style>
<header class="site-header{% if _forceSolid %} is-solid{% endif %}" data-header{% if _forceSolid %} data-force-solid="true"{% endif %}>
  <div class="site-header__inner">
    <a class="site-header__logo" href="/" aria-label="{{ nav.logoAlt }} – accueil"><img src="{{ nav.logo }}" alt="{{ nav.logoAlt }}"></a>
    <nav class="site-header__nav" aria-label="Navigation principale">
      {% for item in nav.links %}<a href="{{ item.url }}">{{ item.label }}</a>{% endfor %}
    </nav>
    <a class="site-header__cta" href="{{ nav.ctaUrl }}">{{ nav.ctaLabel }}<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
    <button class="site-header__burger" data-burger type="button" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="mobile-drawer"><span></span><span></span><span></span></button>
  </div>
  <nav class="site-drawer" id="mobile-drawer" aria-label="Menu mobile">
    {% for item in nav.links %}<a href="{{ item.url }}">{{ item.label }}</a>{% endfor %}
    <a href="{{ nav.ctaUrl }}">{{ nav.ctaLabel }}</a>
  </nav>
</header>
<script data-site-header>
(function () {
  var h = document.querySelector('[data-header]');
  if (!h) return;
  var b = h.querySelector('[data-burger]');
  function close() {
    h.classList.remove('is-open');
    if (b) { b.setAttribute('aria-expanded', 'false'); b.setAttribute('aria-label', 'Ouvrir le menu'); }
  }
  if (b) {
    b.addEventListener('click', function () {
      var open = h.classList.toggle('is-open');
      b.setAttribute('aria-expanded', open ? 'true' : 'false');
      b.setAttribute('aria-label', open ? 'Fermer le menu' : 'Ouvrir le menu');
    });
  }
  h.querySelectorAll('.site-drawer a').forEach(function (a) {
    a.addEventListener('click', close);
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && h.classList.contains('is-open')) close();
  });
  function onScroll() {
    if (h.dataset.forceSolid === 'true') return;
    h.classList.toggle('is-solid', window.scrollY > 40);
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
})();
</script>
