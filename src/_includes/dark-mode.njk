<style data-dark-mode>
/* === DARK MODE ===
   Override des couleurs clés sur html[data-theme="dark"]. Les éléments
   déjà navy (header, CTAs, footer) restent visuellement OK ; on inverse
   essentiellement les zones cream/blanches en sombre, et le texte sombre
   en clair. */

/* Body + wrapper Framer principal */
html[data-theme="dark"] body,
html[data-theme="dark"] .framer-zexGJ {
  background: #0a0f1e !important;
}

/* Cards / blocs blancs (Framer token --token-a5026c65 = #fff) → bleu nuit */
html[data-theme="dark"] body {
  --token-8418968f-be15-4afa-ba70-9e8ef780073e: #0a0f1e !important;
  --token-a5026c65-8ddb-4a17-a393-1692158bf079: #181f3a !important;
  --token-4c25a5f2-ebc4-400d-b160-f0725e3ff197: #e8eaf5 !important;
  --token-8181bcf6-09e7-4426-b465-9c87a416ef62: #e8eaf5 !important;
}

/* Sections custom (.faq, .castmate-faq, autres backgrounds clairs) */
html[data-theme="dark"] .faq { background: #0f1530 !important; }
html[data-theme="dark"] .faq__box { border-color: rgba(255, 255, 255, .08) !important; }
html[data-theme="dark"] .faq__left h2,
html[data-theme="dark"] .faq__eyebrow,
html[data-theme="dark"] .faq__q { color: #e8eaf5 !important; }
html[data-theme="dark"] .faq__sub,
html[data-theme="dark"] .faq__a { color: #b8bdd1 !important; }
html[data-theme="dark"] .faq__item { border-top-color: rgba(255, 255, 255, .08) !important; }
html[data-theme="dark"] .faq__toggle {
  background: #181f3a !important;
  border-color: rgba(255, 255, 255, .12) !important;
}
html[data-theme="dark"] .faq__toggle::before,
html[data-theme="dark"] .faq__toggle::after { background: #e8eaf5 !important; }
html[data-theme="dark"] .faq__item[open] .faq__toggle {
  background: #d1e2ff !important;
  border-color: #d1e2ff !important;
}
html[data-theme="dark"] .faq__item[open] .faq__toggle::before,
html[data-theme="dark"] .faq__item[open] .faq__toggle::after { background: #081131 !important; }

/* Pop-up confirmation form (carte blanche → carte dark) */
html[data-theme="dark"] .cm-popup__card { background: #181f3a !important; }
html[data-theme="dark"] .cm-popup__title { color: #e8eaf5 !important; }
html[data-theme="dark"] .cm-popup__msg { color: #b8bdd1 !important; }

/* Drawer mobile (carte blanche → carte dark) */
html[data-theme="dark"] .site-header.is-open .site-drawer { background: #181f3a !important; }
html[data-theme="dark"] .site-header.is-open .site-drawer a { color: #e8eaf5 !important; }

/* Forme du toggle dark mode */
.site-header__theme {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  background: none;
  border: 1px solid rgba(255, 255, 255, .15);
  border-radius: 50%;
  cursor: pointer;
  margin-left: 12px;
  padding: 0;
  color: #fff;
  transition: background-color .2s ease, border-color .2s ease;
}
.site-header__theme:hover { background: rgba(255, 255, 255, .08); border-color: rgba(255, 255, 255, .35); }
.site-header__theme svg { width: 16px; height: 16px; display: block; }
.site-header__theme .moon { display: block; }
.site-header__theme .sun  { display: none; }
html[data-theme="dark"] .site-header__theme .moon { display: none; }
html[data-theme="dark"] .site-header__theme .sun  { display: block; }
</style>
<script>
(function () {
  // Pré-applique le thème AVANT le render pour éviter le flash clair.
  var saved = null;
  try { saved = localStorage.getItem('castmate-theme'); } catch (e) {}
  var prefersDark = window.matchMedia && matchMedia('(prefers-color-scheme: dark)').matches;
  var theme = saved || (prefersDark ? 'dark' : 'light');
  document.documentElement.setAttribute('data-theme', theme);

  function bind() {
    var btn = document.querySelector('[data-theme-toggle]');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var cur = document.documentElement.getAttribute('data-theme') || 'light';
      var next = cur === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      try { localStorage.setItem('castmate-theme', next); } catch (e) {}
      btn.setAttribute('aria-label', next === 'dark' ? 'Passer en mode clair' : 'Passer en mode sombre');
      btn.setAttribute('aria-pressed', next === 'dark' ? 'true' : 'false');
    });
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', bind);
  else bind();
})();
</script>
